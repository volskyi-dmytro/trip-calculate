# ========================================
# Database Configuration
# ========================================
DATABASE_URL=jdbc:postgresql://localhost:5432/tripplanner
DATABASE_USERNAME=tripplanner
DATABASE_PASSWORD=changeme

# ========================================
# Google OAuth2 Configuration
# ========================================
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ========================================
# Application Configuration
# ========================================
# Use 'dev' for local development with H2 database
# Leave empty or use 'prod' for production with PostgreSQL
SPRING_PROFILES_ACTIVE=dev

# ========================================
# Observability — Langfuse (M4/M5)
# ========================================
# Langfuse project public + secret keys (obtained from http://localhost:3001
# after first-time setup; see docs/observability-setup.md).
LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_SECRET_KEY=sk-lf-placeholder
# Internal URL — used by Spring Boot to reach Langfuse over the compose network.
LANGFUSE_HOST=http://langfuse-web:3000

# Langfuse auth secrets — generate each with: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32
LANGFUSE_SALT=replace-with-openssl-rand-hex-32
LANGFUSE_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32
LANGFUSE_NEXTAUTH_URL=http://localhost:3001

# OTEL Collector Basic Auth header value for Langfuse trace ingestion.
# Generate with: echo -n "pk-lf-...:sk-lf-..." | base64
# Then set: LANGFUSE_OTEL_AUTH=Basic <base64-output>
LANGFUSE_OTEL_AUTH=Basic replace-with-base64-encoded-public-and-secret-key

# ========================================
# Observability — ClickHouse (M4/M5)
# ========================================
CLICKHOUSE_USER=langfuse
CLICKHOUSE_PASSWORD=replace-with-strong-password
CLICKHOUSE_DB=langfuse

# ========================================
# Observability — MinIO (M4/M5)
# ========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-strong-password
LANGFUSE_S3_BUCKET=langfuse-events
LANGFUSE_S3_REGION=us-east-1

# ========================================
# Observability — Redis (M4/M5)
# ========================================
# Leave empty to run Redis without a password (local dev only).
# Set a value for production.
REDIS_AUTH=

# ========================================
# Observability — Grafana (M4/M5)
# ========================================
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password
