# LangGraph agent service — environment variables
# Copy to agent/.env and fill in real values.
# NEVER commit a .env file with real secrets.

# --- Required for M2 ---

# PostgreSQL connection string for LangGraph checkpoint + store tables.
# Use the `langgraph` database (separate from the Spring Boot tripplanner DB).
PG_URL=postgresql://tripplanner:password@postgres:5432/langgraph

# Shared secret between Spring Boot (InternalTokenIssuer) and this service (verify_internal_jwt).
# Must be identical on both sides. Generate with: openssl rand -hex 32
INTERNAL_JWT_SECRET=<32-byte hex — must match Spring Boot INTERNAL_JWT_SECRET>

# Anthropic API key for Claude model calls.
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Mapbox access token for the geocode tool (Geocoding v5).
MAPBOX_TOKEN=<your-mapbox-token>

# --- Deferred to M4 ---
# OpenTripMap API key (pois_nearby tool)
# OTM_KEY=...

# --- Deferred to M5 ---
# Gemini API key (fallback model in full routing chain)
# GEMINI_API_KEY=...

# OpenRouter API key (last-ditch fallback)
# OPENROUTER_API_KEY=<your-openrouter-api-key>

# --- Observability (M4 infra ready; M5 wires the SDK) ---

# Langfuse observability — obtain keys from http://localhost:3001 after first-time setup.
# See docs/observability-setup.md for the full setup procedure.
LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_SECRET_KEY=sk-lf-placeholder
LANGFUSE_HOST=http://langfuse-web:3000

# OpenTelemetry collector — agent pushes spans/metrics here over gRPC.
# M5 will wire langchain-opentelemetry / opentelemetry-sdk to emit to this endpoint.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=tripcalc-langgraph-agent

# M5 trace metadata contract (emitted on every LangGraph run):
# metadata = {
#   "langfuse_user_id": uid,          # Google sub from the verified JWT
#   "langfuse_session_id": sid,       # thread_id (= LangGraph checkpoint thread)
#   "langfuse_tags": ["trip-planner", "v1"]
# }
# The langgraph-architect must pass this dict to the Langfuse() client or
# the @traceable decorator in M5. The shape above is the M4/M5 hand-off contract.
