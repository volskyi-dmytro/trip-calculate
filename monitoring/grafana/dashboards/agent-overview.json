{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "TripCalculate LangGraph agent observability — sessions, steps, tools, cost, budget, cache. Panels show 'No data' until M5 wires the OTEL SDK.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Sessions",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "description": "Total agent sessions broken down by terminal status (ok / error / budget_blocked / timeout). Counter — shows rate over selected window.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byLabelValue", "options": { "label": "status", "value": "error" } },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byLabelValue", "options": { "label": "status", "value": "ok" } },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["lastNotNull", "sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "sum by (status) (rate(agent_sessions_total{status=~\"$status\"}[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Agent Sessions Rate (by status)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "description": "Cumulative session counts by status since last restart.",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "sum by (status) (agent_sessions_total)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Agent Sessions Total (cumulative)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Steps per Session",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "description": "Histogram quantiles for LangGraph steps (tool calls + model calls) per session. p95 > 15 means ModelCallLimitMiddleware may not be active.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(agent_steps_per_session_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_steps_per_session_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(agent_steps_per_session_bucket[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Steps per Session (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Tool Calls",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "description": "Tool call rate by tool_name and status. Helps spot individual tools stuck in error loops.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "sum by (tool_name, status) (rate(agent_tool_calls_total[$__rate_interval]))",
          "legendFormat": "{{tool_name}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Tool Calls Rate (by tool + status)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "description": "Success rate per tool. Alert fires when any tool drops below 80% over 5 min (see alert rules).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.8 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "sum by (tool_name) (rate(agent_tool_calls_total{status=\"ok\"}[5m])) / sum by (tool_name) (rate(agent_tool_calls_total[5m]))",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "title": "Tool Success Rate (5m) — alert threshold: 80%",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "LLM Cost",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "description": "Cumulative LLM spend in USD, broken down by model. Counter — use 'increase' over a window for period cost.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "sum by (model) (increase(agent_llm_cost_usd_total[7d]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "LLM Cost — 7d Running Total (by model)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "description": "Total USD spent on LLM calls since last restart.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "sum by (model) (agent_llm_cost_usd_total)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "LLM Cost Total (all time)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 104,
      "title": "Budget & Cache",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "description": "Count of sessions blocked by BudgetGuardMiddleware because the user exceeded their daily or monthly USD cap.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
      "id": 8,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "agent_budget_blocks_total",
          "legendFormat": "budget blocks",
          "refId": "A"
        }
      ],
      "title": "Budget Blocks Total",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "description": "Cache hit counts by layer: redis-grant (AiAccessService), redis-usage (RedisUsageCounters), postgres-store (PostgresStore cross-thread memory). Higher is better.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 37 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["lastNotNull", "sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "sum by (layer) (rate(agent_cache_hits_total[$__rate_interval]))",
          "legendFormat": "{{layer}}",
          "refId": "A"
        }
      ],
      "title": "Cache Hits Rate (by layer)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["agent", "tripcalculate", "langgraph"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus-local" },
        "definition": "label_values(agent_sessions_total, status)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "status",
        "options": [],
        "query": { "query": "label_values(agent_sessions_total, status)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "sort": 0,
        "type": "query",
        "label": "Status"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Agent Overview",
  "uid": "tripcalc-agent-overview",
  "version": 1
}
